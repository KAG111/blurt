<?xml version="1.0" encoding="utf-8"?>
<OfficeApp 
  xmlns="http://schemas.microsoft.com/office/appsharepointdocument/1.1" 
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
  xsi:type="ContentApp">
  
  <!-- Unique ID for the Add-in -->
  <Id>399e8f69-ee83-4f99-afd2-206c553f5977</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Bowerboard</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Bowerboard" />
  <Description DefaultValue="Live word clouds, polls, brainstorms, and sticky notes directly inside your PowerPoint slides." />
  
  <IconUrl DefaultValue="https://bowerboard.app/favicon.ico" />
  <SupportUrl DefaultValue="https://bowerboard.app/" />

  <!-- Register host as PowerPoint Presentation -->
  <Hosts>
    <Host Name="Presentation" />
  </Hosts>

  <DefaultSettings>
    <!-- Point to the live Bowerboard Web URL -->
    <SourceLocation DefaultValue="https://bowerboard.app/" />
    <RequestedWidth>1000</RequestedWidth>
    <RequestedHeight>600</RequestedHeight>
  </DefaultSettings>
  
  <Permissions>ReadWriteDocument</Permissions>
</OfficeApp>
